{
  "name": "majorproject",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm start --prefix backend",
    "backend:dev": "npm run dev --prefix backend",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "build": "npm install --prefix backend && npm install --prefix client && npm run client:build",
    "dev": "concurrently \"npm run backend:dev\" \"npm run client:dev\""
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
